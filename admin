<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ceddy Vandyck - Online CV</title>
    <style>
        .ai-widget-container {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 90%;
            max-width: 500px;
            height: 600px;
            max-height: 80vh;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
            border-radius: 12px;
            overflow: hidden;
            z-index: 9999;
        }
        .ai-chat-box {
            display: flex;
            flex-direction: column;
            width: 100%;
            height: 100%;
            background: #ffffff;
        }
        .ai-chat-header {
            background-color: #007bff;
            color: white;
            padding: 15px;
            font-weight: bold;
            font-family: sans-serif;
        }
    </style>
</head>
<body>

    <!-- AI WIDGET CONTAINER - NU ALTIJD CENTRAAL EN OPEN -->
    <div id="aiWidget" class="ai-widget-container">
        <div id="aiChatBox" class="ai-chat-box">
            <div class="ai-chat-header">
                <span>Ceddy's AI Assistent 🤖</span>
            </div>
            <!-- De iframe vult de container volledig -->
            <div class="ai-chat-body" id="chatbotVak" style="overflow: hidden; height: 100%;"></div>
        </div>
    </div>

    <script>
        window.addEventListener("DOMContentLoaded", function() {
            const containerVak = document.getElementById("chatbotVak");
            
            if (containerVak) {
                const linkDeel1 = "https://huggingface.co/";
                const linkDeel2 = "spaces/CeddyVandyck/ceddy-portfolio-ai";
                const linkDeel3 = "/embed/?user=Kris&role=admin";

                const directEmbedUrl = linkDeel1 + linkDeel2 + linkDeel3;

                containerVak.innerHTML = `
                    <iframe 
                        src="${directEmbedUrl}" 
                        width="100%" 
                        height="100%" 
                        style="border:none; overflow:hidden; background-color:transparent;" 
                        allow="accelerometer; gyroscope; microphone">
                    </iframe>`;
            }
        });
    </script>
</body>
</html>
